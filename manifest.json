{
  "manifest_version": 3,
  "name": "Manga Downloader Premium",
  "version": "1.0.0",
  "description": "Tiện ích tải ảnh truyện tranh cao cấp, hỗ trợ tự động nhận diện và tải ảnh từ nhiều nguồn.",
  "permissions": [
    "storage",
    "downloads",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/grabber.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
